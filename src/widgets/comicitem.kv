#:kivy 2.3.0
#:import RetryImage widgets.image.RetryImage

<ComicItem>:
    height: dp(100)
    size_hint_y: None
    RetryImage:
        id: image
        size_hint_x: None
        path: root.comic.thumb.path
        width: self.height * 0.7071
        fit_mode: 'cover'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(2)
        Label:
            text: root.comic.title
            text_size: self.width, None
            size_hint: 1, None
            height: self.texture_size[1]
            #valign: 'top'
            halign: 'left'
            max_lines: 2
        TinyLabel:
            text: root.comic.author
            text_size: self.size
            size_hint_y: None
            height: dp(16)
            color: rgba('#000000cc')
            halign: 'left'
            shorten: True
            shorten_from: 'right'
        Label:
            text: '分类：' + ' '.join(root.comic.categories)
            shorten: True
            shorten_from: 'right'
            text_size: self.size
            halign: 'left'
            font_size: dp(14)
            size_hint_y: None
            height: self.texture_size[1]
        TinyLabel:
            text: '观看：' + str(root.comic.views) + ' 喜欢：' + str(root.comic.likes)
            text_size: self.size
            valign: 'bottom'
            halign: 'left'
